# ─── Zorunlu ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Opsiyonel: Yüksek Kalite Ses ──────────────
ELEVENLABS_API_KEY=           # Boş bırakılırsa pyttsx3 kullanılır
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ─── Opsiyonel: Gelişmiş Wake Word ─────────────
PICOVOICE_API_KEY=            # Boş bırakılırsa Whisper ile algılanır

# ─── Dil ve Model ───────────────────────────────
STT_LANGUAGE=tr               # tr veya en
WHISPER_MODEL=base            # tiny, base, small, medium, large
GEMINI_MODEL=gemini-3.5-flash # daha ucuz/hızlı: gemini-3.1-flash-lite

# ─── Sunucu ─────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8765
